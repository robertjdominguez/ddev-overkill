# Database
POSTGRES_PASSWORD=changeme
POSTGRES_DB=mysite

# Hasura
HASURA_GRAPHQL_ADMIN_SECRET=changeme
HASURA_GRAPHQL_JWT_SECRET={"type":"HS256","key":"replace-with-a-secure-256-bit-key"}
HASURA_GRAPHQL_DATABASE_URL=postgres://postgres:changeme@postgres:5432/mysite

# Actions service
OPENAI_API_KEY=sk-your-openai-api-key
ACTIONS_URL=http://actions:3001/actions

# Frontend (used during build and dev)
VITE_HASURA_GRAPHQL_URL=http://localhost:8080/v1/graphql
VITE_HASURA_ADMIN_SECRET=changeme

# Seed script
HASURA_GRAPHQL_ENDPOINT=http://hasura:8080/v1/graphql
HASURA_ADMIN_SECRET=changeme
POSTS_DIR=/posts
PROJECTS_DIR=/projects

# Admin auth
HASURA_GRAPHQL_JWT_KEY=replace-with-a-secure-256-bit-key
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2a$10$replace-with-bcrypt-hash

# MinIO (object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme
MINIO_BUCKET=assets
