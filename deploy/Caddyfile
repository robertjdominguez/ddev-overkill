{$DOMAIN:localhost}, www.{$DOMAIN:localhost} {
    # Hasura API (v1 + v2) and console
    handle /v1/* {
        reverse_proxy hasura:8080
    }
    handle /v2/* {
        reverse_proxy hasura:8080
    }
    handle /console/* {
        reverse_proxy hasura:8080
    }

    # Object storage (strip /storage prefix, proxy to MinIO)
    handle_path /storage/* {
        reverse_proxy minio:9000
        header Cache-Control "public, max-age=31536000, immutable"
    }

    # Actions API (strip /api prefix, proxy to actions server)
    handle_path /api/* {
        reverse_proxy actions:3001
    }

    # Social media bot OG tags
    @bot header_regexp User-Agent (?i)(facebookexternalhit|Twitterbot|LinkedInBot|Slackbot|Discordbot|WhatsApp|TelegramBot|Googlebot|bingbot)
    handle @bot {
        rewrite * /og?path={uri}
        reverse_proxy actions:3001
    }

    # Health check
    handle /health {
        respond "healthy" 200
    }

    # Frontend SPA
    handle {
        root * /srv
        try_files {path} /index.html
        file_server

        @static path *.js *.css *.png *.jpg *.jpeg *.gif *.ico *.svg *.woff *.woff2
        header @static Cache-Control "public, max-age=31536000, immutable"
    }
}
